# Steinz Labs — Environment Variables
# Copy to .env.local for local development. Never commit .env.local.
# Production values live in Vercel → Project Settings → Environment Variables.
#
# Convention:
#   NEXT_PUBLIC_* → exposed to the browser bundle. Anything in here is public.
#   Everything else → server-only. Read inside API routes / server components.

# ─── Site ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://nakalabs.xyz
NODE_ENV=development

# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Bypasses RLS — server-side only, never expose. Use getSupabaseAdmin().
SUPABASE_SERVICE_ROLE_KEY=
# Optional, only if a webhook from Supabase posts back to /api/webhooks/supabase
SUPABASE_WEBHOOK_SECRET=

# ─── Anthropic (Claude) ─────────────────────────────────────────────────────
# Used by VTX Agent. Sonnet for fast queries, Opus for advisor escalation.
ANTHROPIC_API_KEY=

# ─── Alchemy (EVM RPC + webhooks) ───────────────────────────────────────────
# Server-side key. Use this from API routes; never bundle the EVM RPC key
# into the client (NEXT_PUBLIC_ALCHEMY_API_KEY was deprecated for that reason).
ALCHEMY_API_KEY=
# Webhook signing keys — comma-separated list, one per chain webhook.
# Required in production; absence will cause /api/webhooks/alchemy-whale to
# fail closed with 401.
ALCHEMY_WEBHOOK_SIGNING_KEYS=
# Legacy single-key var, still honored for backwards compat.
ALCHEMY_WEBHOOK_SIGNING_KEY=
# Local-only escape hatch for unsigned webhooks (set explicitly to "true").
# Ignored when NODE_ENV=production.
ALCHEMY_WEBHOOK_DEV_BYPASS=

# ─── Helius (Solana RPC + webhooks) ─────────────────────────────────────────
HELIUS_API_KEY=
# Custom Authorization header value configured on Helius webhook.
# Compared with crypto.timingSafeEqual.
HELIUS_WEBHOOK_SECRET=
HELIUS_WEBHOOK_DEV_BYPASS=

# ─── Other RPC fallbacks (optional) ─────────────────────────────────────────
NEXT_PUBLIC_ALCHEMY_RPC=

# ─── 0x (EVM swap aggregator) ────────────────────────────────────────────────
ZX_API_KEY=
NEXT_PUBLIC_ZX_API_KEY=

# ─── Jupiter (Solana swap aggregator) ───────────────────────────────────────
# No key required for the public REST endpoints; left here for completeness
# in case a paid tier is enabled later.

# ─── CoinGecko ──────────────────────────────────────────────────────────────
COINGECKO_API_KEY=
COINGECKO_PLAN=demo

# ─── DexScreener / GoPlus ───────────────────────────────────────────────────
GOPLUS_API_KEY=
GOPLUS_TIMEOUT_MS=15000

# ─── LunarCrush ─────────────────────────────────────────────────────────────
LUNARCRUSH_API_KEY=

# ─── Arkham ──────────────────────────────────────────────────────────────────
ARKHAM_API_KEY=

# ─── Birdeye (Solana market data) ───────────────────────────────────────────
BIRDEYE_API_KEY=

# ─── Resend (transactional email) ───────────────────────────────────────────
RESEND_API_KEY=

# ─── Telegram bot ────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
# Set to a long random string; Telegram echoes it in the X-Telegram-Bot-Api-Secret-Token header.
TELEGRAM_WEBHOOK_SECRET=

# ─── Upstash Redis (rate limit + cache) ─────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Sentry ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ─── PostHog (analytics) ────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# ─── Auth ────────────────────────────────────────────────────────────────────
# Minimum 32 random chars: openssl rand -base64 32
JWT_SECRET=
SUPABASE_JWT_SECRET=
# Static admin bearer for /admin/* layout access. Long random string.
ADMIN_BEARER_TOKEN=

# ─── Cloudflare Turnstile (CAPTCHA on auth flows) ───────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ─── Vercel Cron ─────────────────────────────────────────────────────────────
# Vercel sets this automatically when calling /api/cron/*. Routes verify it.
CRON_SECRET=
